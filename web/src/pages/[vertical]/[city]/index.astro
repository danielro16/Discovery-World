---
import Base from '../../../layouts/Base.astro';
import BusinessCard from '../../../components/BusinessCard.astro';
import { getVerticals, getCities, getPlaces, getStats, formatCityName, formatCitySlug, VERTICAL_COLORS, VERTICAL_EMOJIS } from '../../../utils/data';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = () => {
  const verticals = getVerticals();
  const paths: any[] = [];
  for (const v of verticals) {
    for (const citySlug of getCities(v.name)) {
      paths.push({
        params: { vertical: v.name, city: formatCitySlug(citySlug) },
        props: { vertical: v, citySlug, cityName: formatCityName(citySlug) },
      });
    }
  }
  return paths;
};

const { vertical, citySlug, cityName } = Astro.props;
const allPlaces = getPlaces(vertical.name, citySlug);
const stats = getStats(allPlaces);
const colors = VERTICAL_COLORS[vertical.name] || VERTICAL_COLORS.dentists;
const emoji = VERTICAL_EMOJIS[vertical.name] || '📍';
const cityUrlSlug = formatCitySlug(citySlug);

// Sort: rated/reviewed first, then by profile completeness
const sortedPlaces = [...allPlaces].sort((a, b) => {
  const ratingDiff = (b.rating ?? -1) - (a.rating ?? -1);
  if (ratingDiff !== 0) return ratingDiff;
  return (b.profile_completeness ?? 0) - (a.profile_completeness ?? 0);
});

// Render top 50 as HTML — keeps page fast even for 17K-record cities
const PAGE_SIZE = 50;
const displayPlaces = sortedPlaces.slice(0, PAGE_SIZE);
const hasMore = allPlaces.length > PAGE_SIZE;

const schemaJson = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": `${vertical.display_name} in ${cityName}`,
  "numberOfItems": allPlaces.length,
  "itemListElement": sortedPlaces.slice(0, 20).map((p, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "item": {
      "@type": vertical.schema_type,
      "name": p.name,
      "address": p.address,
    },
  })),
});
---

<Base
  title={`${vertical.display_name} in ${cityName}`}
  description={`Find the best ${vertical.display_name.toLowerCase()} in ${cityName}. ${stats.total} businesses with ratings, reviews, and verified profiles.`}
  schemaJson={schemaJson}
>
  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-10">
    <!-- Header -->
    <div class="mb-8">
      <div class="flex items-center gap-2 text-sm text-gray-400 mb-3">
        <a href="/" class="hover:text-gray-600">Home</a>
        <span>/</span>
        <a href={`/${vertical.name}/`} class="hover:text-gray-600">{vertical.display_name}</a>
        <span>/</span>
        <span class="text-gray-600">{cityName}</span>
      </div>
      <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900">
        <span class="mr-2">{emoji}</span>
        {vertical.display_name} in {cityName}
      </h1>
      <p class="mt-2 text-gray-400">{stats.total} businesses found · Updated {new Date().toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}</p>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-8">
      <div class="rounded-2xl p-4 text-center" style={`background: ${colors.bg}`}>
        <div class="text-2xl font-extrabold" style={`color: ${colors.accent}`}>{stats.total}</div>
        <div class="text-xs text-gray-400 mt-1">Total Listed</div>
      </div>
      <div class="rounded-2xl p-4 text-center" style={`background: ${colors.bg}`}>
        <div class="text-2xl font-extrabold" style={`color: ${colors.accent}`}>{stats.avgRating || '—'}</div>
        <div class="text-xs text-gray-400 mt-1">Avg Rating</div>
      </div>
      <div class="rounded-2xl p-4 text-center" style={`background: ${colors.bg}`}>
        <div class="text-2xl font-extrabold" style={`color: ${colors.accent}`}>{stats.withWebsite}</div>
        <div class="text-xs text-gray-400 mt-1">With Website</div>
      </div>
      <div class="rounded-2xl p-4 text-center" style={`background: ${colors.bg}`}>
        <div class="text-2xl font-extrabold" style={`color: ${colors.accent}`}>{stats.enriched}</div>
        <div class="text-xs text-gray-400 mt-1">Verified</div>
      </div>
    </div>

    <!-- Search/Filter -->
    <div class="mb-6">
      <input
        type="text"
        id="search-input"
        placeholder={`Search ${vertical.display_name.toLowerCase()} by name or address...`}
        class="w-full px-5 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 text-sm"
        style={`--tw-ring-color: ${colors.accent}40`}
      />
      <div class="flex gap-2 mt-3">
        <button data-sort="rating" class="sort-btn text-xs font-medium px-3 py-1.5 rounded-full border border-gray-200 hover:border-gray-300 transition-colors">
          ★ Top Rated
        </button>
        <button data-sort="reviews" class="sort-btn text-xs font-medium px-3 py-1.5 rounded-full border border-gray-200 hover:border-gray-300 transition-colors">
          Most Reviewed
        </button>
        <button data-sort="name" class="sort-btn text-xs font-medium px-3 py-1.5 rounded-full border border-gray-200 hover:border-gray-300 transition-colors">
          A-Z
        </button>
      </div>
    </div>

    <!-- Business List -->
    <div id="business-list" class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {displayPlaces.map(place => (
        <BusinessCard place={place} vertical={vertical.name} city={cityUrlSlug} />
      ))}
    </div>

    <p id="no-results" class="hidden text-center text-gray-400 py-12">No businesses match your search.</p>

    <!-- Note for large datasets -->
    {hasMore && (
      <p class="mt-8 text-center text-sm text-gray-400">
        Showing top {PAGE_SIZE} of {stats.total} businesses, sorted by rating.
        Use the search box above to find a specific business by name or address.
      </p>
    )}
  </section>

  <script>
    const input = document.getElementById('search-input') as HTMLInputElement;
    const list = document.getElementById('business-list')!;
    const cards = Array.from(list.children) as HTMLElement[];
    const noResults = document.getElementById('no-results')!;

    input?.addEventListener('input', () => {
      const q = input.value.toLowerCase().trim();
      let visible = 0;
      cards.forEach(card => {
        const name = card.dataset.name || '';
        const address = card.dataset.address || '';
        const show = !q || name.includes(q) || address.includes(q);
        card.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      noResults.classList.toggle('hidden', visible > 0);
    });

    document.querySelectorAll('.sort-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const sort = (btn as HTMLElement).dataset.sort!;
        const sorted = [...cards].sort((a, b) => {
          if (sort === 'rating') return (parseFloat(b.dataset.rating!) || 0) - (parseFloat(a.dataset.rating!) || 0);
          if (sort === 'reviews') return (parseInt(b.dataset.reviews!) || 0) - (parseInt(a.dataset.reviews!) || 0);
          return (a.dataset.name || '').localeCompare(b.dataset.name || '');
        });
        sorted.forEach(c => list.appendChild(c));
        document.querySelectorAll('.sort-btn').forEach(b => b.classList.remove('bg-gray-100'));
        btn.classList.add('bg-gray-100');
      });
    });
  </script>
</Base>
