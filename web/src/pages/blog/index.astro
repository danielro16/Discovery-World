---
import Base from '../../layouts/Base.astro';
---

<Base title="Blog" description="Guides, rankings, and insights about local businesses.">
  <section class="max-w-4xl mx-auto px-4 sm:px-6 py-12">
    <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 text-center">Blog</h1>
    <p class="text-center text-gray-400 mt-3 mb-10">Guides, rankings, and insights about local businesses</p>

    <div class="text-center py-16">
      <div class="text-5xl mb-4">📝</div>
      <p class="text-gray-400 text-lg">Blog posts coming soon!</p>
      <p class="text-gray-300 text-sm mt-2">Run the content generation pipeline to create articles.</p>
    </div>
  </section>
</Base>
