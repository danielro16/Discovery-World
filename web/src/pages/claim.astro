---
import Base from '../layouts/Base.astro';
---

<Base title="Claim Your Business Profile" description="Own a business? Claim your profile to stand out in AI recommendations.">
  <section class="max-w-2xl mx-auto px-4 sm:px-6 py-12">
    <div class="text-center mb-10">
      <div class="text-5xl mb-4">🏢</div>
      <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900">Claim Your Profile</h1>
      <p class="mt-3 text-gray-400">Stand out in AI recommendations and connect with more customers</p>
    </div>

    <!-- Benefits -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-10">
      <div class="rounded-2xl bg-blue-50 p-5 text-center">
        <div class="text-2xl mb-2">🤖</div>
        <h3 class="font-bold text-sm text-gray-700">AI Visibility</h3>
        <p class="text-xs text-gray-400 mt-1">Get recommended by AI agents and LLMs</p>
      </div>
      <div class="rounded-2xl bg-purple-50 p-5 text-center">
        <div class="text-2xl mb-2">✅</div>
        <h3 class="font-bold text-sm text-gray-700">Verified Badge</h3>
        <p class="text-xs text-gray-400 mt-1">Build trust with a verified profile</p>
      </div>
      <div class="rounded-2xl bg-teal-50 p-5 text-center">
        <div class="text-2xl mb-2">📊</div>
        <h3 class="font-bold text-sm text-gray-700">Complete Profile</h3>
        <p class="text-xs text-gray-400 mt-1">Add services, photos, and more</p>
      </div>
    </div>

    <!-- Form -->
    <form
      class="rounded-2xl border border-gray-100 p-6 space-y-5"
      action="https://formsubmit.co/your@email.com"
      method="POST"
    >
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Business Name</label>
        <input type="text" name="business_name" required
          class="w-full px-4 py-2.5 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-blue-400/40 text-sm"
          placeholder="e.g. Miami Dental Clinic"
        />
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Your Name</label>
        <input type="text" name="contact_name" required
          class="w-full px-4 py-2.5 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-blue-400/40 text-sm"
          placeholder="Your full name"
        />
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
        <input type="email" name="email" required
          class="w-full px-4 py-2.5 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-blue-400/40 text-sm"
          placeholder="you@business.com"
        />
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Phone</label>
        <input type="tel" name="phone"
          class="w-full px-4 py-2.5 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-blue-400/40 text-sm"
          placeholder="(555) 123-4567"
        />
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Your Role</label>
        <select name="role" class="w-full px-4 py-2.5 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-blue-400/40 text-sm">
          <option value="owner">Owner</option>
          <option value="manager">Manager</option>
          <option value="marketing">Marketing</option>
          <option value="other">Other</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Message (optional)</label>
        <textarea name="message" rows="3"
          class="w-full px-4 py-2.5 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-blue-400/40 text-sm"
          placeholder="Anything else we should know?"
        ></textarea>
      </div>
      <input type="hidden" name="_subject" value="New Claim Request - AgentReady" />

      <button type="submit" class="w-full bg-gradient-to-r from-blue-500 via-purple-500 to-teal-400 text-white font-bold py-3 rounded-xl hover:scale-[1.02] transition-transform shadow-lg">
        Submit Claim Request
      </button>
      <p class="text-xs text-gray-300 text-center">We'll verify your ownership and get back to you within 24-48 hours.</p>
    </form>
  </section>
</Base>
