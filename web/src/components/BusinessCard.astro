---
import RatingStars from './RatingStars.astro';
import type { Place } from '../utils/data';
import { slugify, VERTICAL_COLORS } from '../utils/data';

interface Props {
  place: Place;
  vertical: string;
  city: string;
}

const { place, vertical, city } = Astro.props;
const colors = VERTICAL_COLORS[vertical] || VERTICAL_COLORS.dentists;
const slug = slugify(place.name);
const href = `/${vertical}/${city}/${slug}/`;
const enriched = place.enriched_data || {};
const tags: string[] = [];

// Check both enriched_data (old) and direct fields (new from heuristic_enrich)
const specialties = enriched.specialties || (place as any).specialties || [];
const cuisineTypes = enriched.cuisine_types || (place as any).cuisine_types || [];
const practiceAreas = enriched.practice_areas || (place as any).practice_areas || [];
const gymType = enriched.gym_type || (place as any).gym_type || '';
const therapyTypes = enriched.therapy_types || (place as any).therapy_types || [];
const langs = enriched.languages_spoken || enriched.languages || (place as any).languages_spoken || (place as any).languages || [];

if (specialties.length) tags.push(...specialties.slice(0, 2));
if (cuisineTypes.length) tags.push(...cuisineTypes.slice(0, 2));
if (practiceAreas.length) tags.push(...practiceAreas.slice(0, 2));
if (gymType) tags.push(gymType);
if (therapyTypes.length) tags.push(...therapyTypes.slice(0, 2));
if (langs.length) tags.push(...langs.filter((l: string) => l.toLowerCase() !== 'english').slice(0, 1));

// Add key boolean highlights as mini-badges
const miniHighlights: string[] = [];
if (enriched.free_consultation || (place as any).free_consultation) miniHighlights.push('Free Consult');
if (enriched.telehealth || (place as any).telehealth) miniHighlights.push('Telehealth');
if (enriched.delivery || (place as any).delivery) miniHighlights.push('Delivery');
if (enriched.open_24h || (place as any).open_24h) miniHighlights.push('24h');
if (enriched.emergency_dentistry || (place as any).emergency_dentistry) miniHighlights.push('Emergency');
if (enriched.free_trial || (place as any).free_trial) miniHighlights.push('Free Trial');
---

<a
  href={href}
  class="card-hover block rounded-2xl border border-gray-100 p-5 bg-white"
  style={`--card-accent: ${colors.accent}`}
  data-name={place.name.toLowerCase()}
  data-rating={place.rating || 0}
  data-reviews={place.review_count}
  data-address={place.address.toLowerCase()}
>
  <div class="flex items-start justify-between gap-3">
    <div class="flex-1 min-w-0">
      <h3 class="font-bold text-gray-900 truncate text-lg">{place.name}</h3>
      <p class="text-sm text-gray-400 mt-0.5 truncate">{place.address}</p>
    </div>
    <div class="shrink-0">
      {place.rating == null && place.review_count === 0 ? (
        <span class="inline-block text-xs font-medium px-2.5 py-1 rounded-full bg-gray-100 text-gray-400">
          New listing
        </span>
      ) : (
        <>
          <RatingStars rating={place.rating} size="sm" />
          <p class="text-xs text-gray-400 text-right mt-0.5">{place.review_count.toLocaleString()} reviews</p>
        </>
      )}
    </div>
  </div>

  {tags.length > 0 && (
    <div class="flex flex-wrap gap-1.5 mt-3">
      {tags.slice(0, 4).map(tag => (
        <span
          class="text-xs font-medium px-2.5 py-0.5 rounded-full"
          style={`background: ${colors.light}; color: ${colors.accent}`}
        >
          {tag}
        </span>
      ))}
    </div>
  )}

  {miniHighlights.length > 0 && (
    <div class="flex flex-wrap gap-1.5 mt-2">
      {miniHighlights.map(h => (
        <span class="text-xs font-semibold px-2 py-0.5 rounded-md border" style={`border-color: ${colors.accent}; color: ${colors.accent}`}>
          {h}
        </span>
      ))}
    </div>
  )}

  <div class="flex items-center gap-4 mt-3 text-sm text-gray-500">
    {place.phone && <span>📞 {place.phone}</span>}
    {place.website && <span>🌐 Website</span>}
  </div>

  <div class="completeness-bar mt-3">
    <div class="completeness-fill" style={`width: ${place.profile_completeness}%`}></div>
  </div>
</a>
